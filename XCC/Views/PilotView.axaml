<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XCC.ViewModels"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="1280"
             x:Class="XCC.Views.PilotView"
             x:DataType="vm:PilotViewModel"
             Background="Black">

  <UserControl.Styles>
    <Style Selector="Button.keypad">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="FontSize" Value="40"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.keypad:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20FFFFFF"/>
    </Style>
    <Style Selector="Button.keypad:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40FFFFFF"/>
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="White"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="0,22"/>
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20FFFFFF"/>
    </Style>
    <Style Selector="Button.action:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40FFFFFF"/>
    </Style>
    <!-- OUI confirmation button — overrides .action colors -->
    <Style Selector="Button.action.danger">
      <Setter Property="BorderBrush" Value="#FF4444"/>
      <Setter Property="Foreground" Value="#FF6666"/>
    </Style>
    <Style Selector="Button.action.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#33FF2222"/>
    </Style>
    <Style Selector="Button.action.danger:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#55FF2222"/>
    </Style>
    <!-- Small "Finir le round" button -->
    <Style Selector="Button.finir">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#CC7744"/>
      <Setter Property="BorderBrush" Value="#CC7744"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="Button.finir:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20CC7744"/>
    </Style>
    <Style Selector="Button.finir:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40CC7744"/>
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <vm:PilotViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="3*,Auto,8*">

    <!-- Number display + prev pilot info + end-round button -->
    <Grid Grid.Row="0" RowDefinitions="*,44">
      <Border Grid.Row="0"
              Background="{Binding NumberBackground}"
              Margin="6,6,6,4"
              CornerRadius="16"
              Padding="20,8">
        <TextBlock Text="{Binding CurrentNumber}"
                   FontSize="100"
                   FontWeight="DemiBold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

      <!-- Fixed-height strip: gray bg, prev pilot info OR race-complete message + finish button -->
      <Border Grid.Row="1" Margin="6,0,6,4" CornerRadius="8" Background="#222222" Padding="12,0">
        <Grid ColumnDefinitions="*,Auto">

          <!-- Left: prev pilot info / race-complete message / rejected pilot -->
          <StackPanel Grid.Column="0" IsVisible="{Binding ShowInfo}"
                      Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="{Binding LastPilotNumber}"
                       FontSize="16" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding LastPilotInfo}"
                       FontSize="13" Foreground="#80FFFFFF"
                       VerticalAlignment="Center"/>
          </StackPanel>

          <TextBlock Grid.Column="0"
                     IsVisible="{Binding ShowRaceComplete}"
                     Text="PASSAGES FINAUX — Course terminée"
                     Foreground="#FF6D00"
                     FontSize="13" FontWeight="Bold" LetterSpacing="1"
                     VerticalAlignment="Center"/>

          <TextBlock Grid.Column="0"
                     IsVisible="{Binding ShowRejected}"
                     Text="{Binding RejectedMessage}"
                     Foreground="#FF4444"
                     FontSize="13" FontWeight="Bold"
                     VerticalAlignment="Center"/>

          <!-- Right: finish button -->
          <Button Grid.Column="1" Classes="finir"
                  Content="Finir le round"
                  Command="{Binding FinishRoundCommand}"
                  VerticalAlignment="Center"/>
        </Grid>
      </Border>
    </Grid>

    <!-- Separator -->
    <Rectangle Grid.Row="1" Height="1" Fill="White"/>

    <!-- Keypad panel -->
    <Grid Grid.Row="2"
          RowDefinitions="*,1,*,1,*,1,*"
          ColumnDefinitions="*,1,*,1,*">

      <Rectangle Grid.Row="1" Grid.ColumnSpan="5" Fill="White"/>
      <Rectangle Grid.Row="3" Grid.ColumnSpan="5" Fill="White"/>
      <Rectangle Grid.Row="5" Grid.ColumnSpan="5" Fill="White"/>
      <Rectangle Grid.Column="1" Grid.RowSpan="7" Fill="White"/>
      <Rectangle Grid.Column="3" Grid.RowSpan="7" Fill="White"/>

      <Button Grid.Row="0" Grid.Column="0" Classes="keypad" Content="1" Command="{Binding AppendDigitCommand}" CommandParameter="1"/>
      <Button Grid.Row="0" Grid.Column="2" Classes="keypad" Content="2" Command="{Binding AppendDigitCommand}" CommandParameter="2"/>
      <Button Grid.Row="0" Grid.Column="4" Classes="keypad" Content="3" Command="{Binding AppendDigitCommand}" CommandParameter="3"/>
      <Button Grid.Row="2" Grid.Column="0" Classes="keypad" Content="4" Command="{Binding AppendDigitCommand}" CommandParameter="4"/>
      <Button Grid.Row="2" Grid.Column="2" Classes="keypad" Content="5" Command="{Binding AppendDigitCommand}" CommandParameter="5"/>
      <Button Grid.Row="2" Grid.Column="4" Classes="keypad" Content="6" Command="{Binding AppendDigitCommand}" CommandParameter="6"/>
      <Button Grid.Row="4" Grid.Column="0" Classes="keypad" Content="7" Command="{Binding AppendDigitCommand}" CommandParameter="7"/>
      <Button Grid.Row="4" Grid.Column="2" Classes="keypad" Content="8" Command="{Binding AppendDigitCommand}" CommandParameter="8"/>
      <Button Grid.Row="4" Grid.Column="4" Classes="keypad" Content="9" Command="{Binding AppendDigitCommand}" CommandParameter="9"/>
      <Button Grid.Row="6" Grid.Column="0" Classes="keypad" Content="⌫" Command="{Binding CorrectCommand}"/>
      <Button Grid.Row="6" Grid.Column="2" Classes="keypad" Content="0" Command="{Binding AppendDigitCommand}" CommandParameter="0"/>
      <Button Grid.Row="6" Grid.Column="4" Classes="keypad" Content="✓" Command="{Binding ValidateCommand}"/>
    </Grid>


<!-- Confirmation overlay — covers full view, last in Grid so it renders on top -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            Background="#CC000000"
            IsVisible="{Binding IsConfirmingEnd}">
      <Border Background="#1C1C1C"
              CornerRadius="16"
              Padding="36,32"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MinWidth="320">
        <StackPanel Spacing="28">
          <TextBlock Text="Finir le round ?"
                     Foreground="White"
                     FontSize="28"
                     FontWeight="Bold"
                     HorizontalAlignment="Center"/>
          <Grid ColumnDefinitions="*,16,*">
            <Button Grid.Column="0"
                    Classes="action"
                    Content="NON"
                    Command="{Binding CancelFinishCommand}"/>
            <Button Grid.Column="2"
                    Classes="action danger"
                    Content="OUI"
                    Command="{Binding ConfirmFinishCommand}"/>
          </Grid>
        </StackPanel>
      </Border>
    </Border>

  </Grid>

</UserControl>
