<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XCC.ViewModels"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="1280"
             x:Class="XCC.Views.EndRoundView"
             x:DataType="vm:EndRoundViewModel"
             Background="Black">

  <UserControl.Styles>
    <Style Selector="Button.outlined">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="White"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="LetterSpacing" Value="1"/>
      <Setter Property="Padding" Value="0,22"/>
    </Style>
    <Style Selector="Button.outlined:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20FFFFFF"/>
    </Style>
    <Style Selector="Button.outlined:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40FFFFFF"/>
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <vm:EndRoundViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- Compact header -->
    <StackPanel Grid.Row="0" Margin="24,28,24,16" Spacing="2">
      <TextBlock Text="{Binding RoundName}"
                 Foreground="White"
                 FontSize="28"
                 FontWeight="Bold"/>
      <Grid ColumnDefinitions="*,*,*,*">
        <TextBlock Grid.Column="0" Text="{Binding HeureFinDisplay}"   Foreground="#80FFFFFF" FontSize="14"/>
        <TextBlock Grid.Column="1" Text="{Binding TempsTotalDisplay}" Foreground="#80FFFFFF" FontSize="14"/>
        <TextBlock Grid.Column="2" Text="{Binding ToursDisplay}"      Foreground="#80FFFFFF" FontSize="14"/>
        <TextBlock Grid.Column="3" Text="{Binding NombrePilotesDisplay}" Foreground="#80FFFFFF" FontSize="14"/>
      </Grid>
    </StackPanel>

    <!-- Separator -->
    <Rectangle Grid.Row="1" Height="1" Fill="#40FFFFFF"/>

    <!-- Column headers — outside ScrollViewer so they stay fixed -->
    <Grid Grid.Row="2"
          ColumnDefinitions="56,*,64,112"
          Margin="24,0"
          Height="36">
      <TextBlock Grid.Column="0" Text="POS"   Foreground="#60FFFFFF" FontSize="12" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="1" Text="PILOTE" Foreground="#60FFFFFF" FontSize="12" LetterSpacing="1" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="TOURS"  Foreground="#60FFFFFF" FontSize="12" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
      <TextBlock Grid.Column="3" Text="HEURE"  Foreground="#60FFFFFF" FontSize="12" LetterSpacing="1" VerticalAlignment="Center" HorizontalAlignment="Right"/>
    </Grid>

    <!-- Placement list -->
    <ScrollViewer Grid.Row="3">
      <ItemsControl ItemsSource="{Binding Standings}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:PlacementEntry">
            <Border Background="{Binding RowBackground}"
                    BorderBrush="#15FFFFFF"
                    BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="56,*,64,112"
                    Margin="24,0"
                    Height="52">
                <!-- Position -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Position}"
                           Foreground="{Binding PositionColor}"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <!-- Pilot number -->
                <TextBlock Grid.Column="1"
                           Text="{Binding PilotNumber}"
                           Foreground="White"
                           FontSize="26"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <!-- Turns -->
                <TextBlock Grid.Column="2"
                           Text="{Binding MaxTurn}"
                           Foreground="#C0FFFFFF"
                           FontSize="18"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                <!-- Last crossing time -->
                <TextBlock Grid.Column="3"
                           Text="{Binding LastTime}"
                           Foreground="#C0FFFFFF"
                           FontSize="16"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Actions -->
    <StackPanel Grid.Row="4"
                Margin="24,12,24,36"
                Spacing="12">
      <Button Content="{Binding CopyLabel}"
              Command="{Binding CopierClassementCommand}"
              Classes="outlined"/>
      <Button Content="EXPORTER"
              Command="{Binding ExporterCommand}"
              Classes="outlined"/>
      <TextBlock Text="{Binding ExportStatus}"
                 Foreground="#80FFFFFF"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 IsVisible="{Binding ExportStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
      <Button Content="NOUVEAU ROUND"
              Command="{Binding NouveauRoundCommand}"
              Classes="outlined"/>
    </StackPanel>

  </Grid>

</UserControl>
