<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:XCC.ViewModels"
             mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="1280"
             x:Class="XCC.Views.EndRoundView"
             x:DataType="vm:EndRoundViewModel"
             Background="Black">

  <UserControl.Styles>
    <Style Selector="Button.outlined">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="White"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="LetterSpacing" Value="1"/>
      <Setter Property="Padding" Value="0,22"/>
    </Style>
    <Style Selector="Button.outlined:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#20FFFFFF"/>
    </Style>
    <Style Selector="Button.outlined:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#40FFFFFF"/>
    </Style>
  </UserControl.Styles>

  <Design.DataContext>
    <vm:EndRoundViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="*,Auto">

    <!-- Stats -->
    <StackPanel Grid.Row="0"
                VerticalAlignment="Top"
                Margin="40,48"
                Spacing="16">
      <TextBlock Text="{Binding NombrePilotesDisplay}"
                 Foreground="White" FontSize="26"/>
      <TextBlock Text="{Binding ToursDisplay}"
                 Foreground="White" FontSize="26"/>
      <TextBlock Text="{Binding TempsTotalDisplay}"
                 Foreground="White" FontSize="26"/>
    </StackPanel>

    <!-- Actions -->
    <StackPanel Grid.Row="1"
                Margin="40,0,40,48"
                Spacing="16">
      <Button Content="EXPORTER"
              Command="{Binding ExporterCommand}"
              Classes="outlined"/>
      <Button Classes="outlined"
              Command="{Binding NouveauRoundCommand}">
        <TextBlock Text="NOUVEAU ROUND"
                   TextAlignment="Center"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   LetterSpacing="1"/>
      </Button>
    </StackPanel>

  </Grid>

</UserControl>
